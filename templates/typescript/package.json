{
  "name": "mcp-typescript-template",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical TypeScript MCP server template — single binary, stdio + Streamable HTTP transports, structured stderr logging, MCP 2025-11-25.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "^22.7.5"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:stdio": "tsx src/index.ts --transport=stdio",
    "start:http": "tsx src/index.ts --transport=http",
    "lint": "eslint src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "ulid": "3.0.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8.61",
    "@typescript-eslint/parser": "^8.61",
    "eslint": "^9",
    "tsx": "^4.22.4",
    "typescript": "^5.7",
    "yaml": "^2.6.0"
  }
}
